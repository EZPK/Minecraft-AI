# Eval / evolution overrides. Copy to `.env.eval`.
#
# Loaded BEFORE `.env`, and dotenv never overrides already-set vars, so anything
# here wins and `.env` fills in the rest (model creds, server host, etc.). Only
# put the values that should DIFFER during evaluation here.

# Use a separate bot account so evaluation doesn't collide with live play.
MC_USERNAME=YourEvalBot

# Fixed "arena" coordinate the bot walks back to before each episode (no /tp
# rights, so it pathfinds home). Pick a spot near renewable resources — trees,
# stone, water — so scenario preconditions usually hold.
EVAL_ARENA_X=0
EVAL_ARENA_Y=64
EVAL_ARENA_Z=0

# Trials per scenario. More trials = better signal on a noisy live world, at the
# cost of time. Start at 3 for the evolution loop; 1 is fine for a quick check.
EVAL_TRIALS=3

# Generations the `npm run evolve` loop runs (also takeable as the first CLI arg:
# `npm run evolve -- 5`).
EVOLVE_GENERATIONS=1

# --- Andy-4 knowledge oracle (optional) -----------------------------------
# Local Minecraft-specialist model the bot can consult via `ask_minecraft_expert`.
# Leave KNOWLEDGE_MODEL unset to disable the tool entirely. Requires Ollama
# running the model: `ollama pull Sweaterdog/Andy-4`.
# These can also live in `.env` so they apply to live play too.
# KNOWLEDGE_MODEL=Sweaterdog/Andy-4
# KNOWLEDGE_BASE_URL=http://localhost:11434
