# ─── Minecraft server ───────────────────────────────────────────────
# Host/port of the server you already run.
MC_HOST=localhost
MC_PORT=25565
# Mineflayer is sensitive to the exact version. Pin it, e.g. 1.20.4.
MC_VERSION=1.20.4
# Auth: "microsoft" (real account, device-code flow on first run) or
# "offline" (cracked/LAN servers, username is free text).
MC_AUTH=microsoft
# For microsoft auth this is the account email; for offline it is the in-game name.
MC_USERNAME=your-bot@example.com
# Your own in-game name. The bot treats this player as its owner/operator.
BOT_OWNER=YourPlayerName

# ─── LLM brain (pi.dev) ─────────────────────────────────────────────
# Which provider the agent's brain uses.
#   openrouter | ollama | lmstudio | openai | anthropic | custom
MODEL_PROVIDER=openrouter
# Model id as the provider names it.
#   openrouter -> e.g. anthropic/claude-opus-4.8  or  meta-llama/llama-3.3-70b-instruct
#   ollama     -> e.g. llama3.1  or  qwen2.5-coder:14b
#   lmstudio   -> the model identifier shown in LM Studio
MODEL_ID=anthropic/claude-opus-4.8
# API key for the provider. Leave blank for local servers (ollama / lmstudio).
MODEL_API_KEY=
# Optional: override the base URL. Defaults per provider:
#   openrouter -> https://openrouter.ai/api/v1
#   ollama     -> http://localhost:11434/v1
#   lmstudio   -> http://localhost:1234/v1
#   openai     -> https://api.openai.com/v1
# Required when MODEL_PROVIDER=custom.
MODEL_BASE_URL=
# Reasoning/thinking support of the chosen model (true/false). Affects thinking level.
MODEL_REASONING=true
# Context window / max output tokens used to describe the model to pi.
MODEL_CONTEXT_WINDOW=200000
MODEL_MAX_TOKENS=8192
# Thinking level: off | minimal | low | medium | high
THINKING_LEVEL=medium
